{
  "name": "rabbit-mq-service",
  "version": "2.0.0",
  "description": "Production-ready RabbitMQ wrapper with reconnection, DLX, confirms, and multi-worker consumers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "rabbitmq",
    "amqp",
    "message-queue",
    "producer",
    "consumer"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.6.4",
  "dependencies": {
    "amqplib": "^0.10.8",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@testcontainers/rabbitmq": "^12.0.1",
    "@types/amqplib": "^0.10.7",
    "testcontainers": "^12.0.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
